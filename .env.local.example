# Firebase Configuration for Vite (Frontend Only)
# Copy this file to .env.local and fill in your Firebase project credentials
# 
# How to get these values:
# 1. Go to Firebase Console: https://console.firebase.google.com/
# 2. Select your project
# 3. Click Settings (gear icon) > Project Settings
# 4. Scroll to "Your apps" section
# 5. Click on your web app
# 6. Copy the values from the firebaseConfig object

# ============================================
# FIREBASE CLIENT CONFIG (Required)
# ============================================

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# EXAMPLE VALUES (DO NOT USE)
# ============================================
# VITE_FIREBASE_API_KEY=AIzaSyDummyKeyWithValidFormat1234567890
# VITE_FIREBASE_AUTH_DOMAIN=elshorbagy-store.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=elshorbagy-store
# VITE_FIREBASE_STORAGE_BUCKET=elshorbagy-store.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
# VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890abcdef
